{
  "manifest_version": 3,
  "name": "Orion | Secure Password Manager",
  "description": "The decentralized, tamper-proof secrets engine for the Sui ecosystem.",
  "version": "0.1.0",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/extension/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "src/extension/content.ts"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "unlimitedStorage",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}